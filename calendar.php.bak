}
.date-mode-row input { accent-color: var(--accent); }
.date-range-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
}
@media (max-width: 560px) {
    .date-range-row { grid-template-columns: 1fr; }
}
</style>

